# Copy to `.env.local` (create next to package.json). Never commit `.env.local`.
# After sharing keys in chat or a ticket, rotate them in Supabase → Project Settings → API.

# ═══════════════════════════════════════════════════════════════════════════
# Supabase — ONLY these three names (three separate lines)
# ═══════════════════════════════════════════════════════════════════════════
#
# Where to copy from: Supabase Dashboard → your project → Project Settings → API
#
#   NEXT_PUBLIC_SUPABASE_URL
#     → "Project URL" (looks like https://xxxxxxxxxxxxx.supabase.co)
#
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#     → "Project API keys" → anon / public key (long JWT starting with eyJ...)
#     → This repo expects the classic anon JWT, not a separate "publishable" key unless
#       your dashboard only shows one public key — use whatever Supabase labels as anon/public for client use.
#
#   SUPABASE_SERVICE_ROLE_KEY
#     → "service_role" / secret key (long JWT, server-only; bypasses RLS)
#
# You do NOT need for this Next.js app:
#   POSTGRES_* , DATABASE_URL , SUPABASE_JWT_SECRET , SUPABASE_URL (duplicate of Project URL),
#   or sb_publishable_* / sb_secret_* unless you add another integration that requires them.
#
# COMMON MISTAKE — invalid (two variable names stuck together; will NOT work):
#   NEXT_PUBLIC_SUPABASE_URLSUPABASE_ANON_KEY=...
#
# CORRECT — two lines, two different names:
#   NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# Admin UI — /admin
# ═══════════════════════════════════════════════════════════════════════════
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# Public site: where gallery + homepage photos come from
# ═══════════════════════════════════════════════════════════════════════════
# Omit → content/photos.ts only. For admin + DB: supabase. For remote JSON or Cloudinary see README.
CONTENT_SOURCE=
# PHOTOS_JSON_URL=
#
# Optional ISR for json/cloudinary (seconds). Admin saves use revalidatePath.
CONTENT_REVALIDATE_SECONDS=

# ═══════════════════════════════════════════════════════════════════════════
# Cloudinary — only if CONTENT_SOURCE=cloudinary
# ═══════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# Contact form
# ═══════════════════════════════════════════════════════════════════════════
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
