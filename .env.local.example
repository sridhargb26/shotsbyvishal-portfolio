# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Photos: omit or leave unset to use content/photos.ts only.
# Set to "cloudinary" to load from folder shotsbyvishal/* (set metadata on each asset).
CONTENT_SOURCE=cloudinary
# Optional: ISR seconds so new Cloudinary uploads show without redeploy (e.g. 120).
CONTENT_REVALIDATE_SECONDS=120

# Email (for contact form)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=vishal@example.com
